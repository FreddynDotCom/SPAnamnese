@inherits LayoutComponentBase
@inject AuthenticationStateProvider AuthStateProvider

<div style="margin-bottom: 5rem;">
    <NavbarLayout />
</div>

<div class="page">
    <div class="page container" style="padding-top: 1rem;">
        <main>
            <article class="content py-4 px-4">
                @Body
            </article>
        </main>
    </div>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && AuthStateProvider is SPAnamnese.Web.Auth.JwtAuthenticationStateProvider jwtProvider)
        {
            await jwtProvider.RecarregarAposConexaoAsync();
        }
    }
}