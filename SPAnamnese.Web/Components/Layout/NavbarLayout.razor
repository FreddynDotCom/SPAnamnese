@inject NavigationManager NavigationManager
@implements IDisposable
@rendermode InteractiveServer

<nav class="navbar bg-navbar fixed-top navbar-expand-lg bg-body-tertiary rounded-3 p-2 shadow m-3">
    <div class="container-fluid">
        <a class="navbar-brand fw-bolder text-success" href="/">@SiteConfig.NomeSite</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse text-center" id="navbarSupportedContent">
            <ul class="nav nav-underline navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item">
                    <a class="nav-link text-success @(urlAtual == "/anamnese" ? "active" : "")" href="/anamnese">Listagem de Anamneses</a>
                </li>
            </ul>

            <div class="d-flex">
                <div class="me-2 align-content-center justify-content-center">
                    <button class="badge bg-success">NOME LOGIN</button>
                </div>
                <button class="btn btn-outline-success">Sair</button>
            </div>
        </div>
    </div>
</nav>

@code {
    private string urlAtual = string.Empty;

    protected override void OnInitialized()
    {
        urlAtual = new Uri(NavigationManager.Uri).AbsolutePath;
        NavigationManager.LocationChanged += AtualizarUrl;
    }

    private void AtualizarUrl(object? sender, LocationChangedEventArgs e)
    {
        urlAtual = new Uri(e.Location).AbsolutePath;
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= AtualizarUrl;
    }
}