@page "/"
@page "/login"

@layout EmptyLayout

@rendermode InteractiveServer

<PageTitle>Login - @SiteConfig.NomeSite</PageTitle>

<div style="position: fixed; inset: 0; display: grid; place-items: center; overflow: hidden;">
    <div style="width: 100%; max-width: 1200px; padding: 1rem;">

        <AnimatedContainer Distance="80"
                           Direction="vertical"
                           Duration="0.9"
                           Ease="power3.out"
                           Delay="0"
                           AnimateOpacity="true"
                           Enabled="@SiteConfig.HabilitarAnimacoes">

            <CardDestaque>
                <div>
                    <h1 class="fw-bold">Bem-vindo(a) de volta!</h1>

                    <form>
                        <div class="mt-5">
                            <label for="cpf" class="text-normal ms-5 mt-4">Cpf</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-123"></i></span>
                                <input id="cpf" class="form-control" type="text" placeholder="123.456.789.00" @bind="cpfDigitado">
                            </div>

                            @if (erroDictionary?.ContainsKey("cpf") == true)
                            {
                                <span class="text-danger">@cpfErroLabel</span>
                            }

                        </div>

                        <div class="mt-3">
                            <label for="password" class="text-normal ms-5">Senha</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-key"></i></span>
                                <input id="password" class="form-control" type="password" placeholder="Insira sua senha" @bind="senhaDigitada">
                            </div>

                            @if (erroDictionary?.ContainsKey("senha") == true)
                            {
                                <span class="text-danger">@senhaErroLabel</span>
                            }

                        </div>



                        <div class="mt-5">
                            
                            <div class="text-center">
                                @if (erroDictionary?.ContainsKey("geral") == true)
                                {
                                    <span class="text-danger fw-bold">@geralErroLabel</span>
                                }
                            </div>

                            <button class="btn btn-primary w-100" type="button" @onclick="TryLogin">Entrar</button>

                            <span style="font-size: 12px;" class="text-normal ps-1">
                                Não tem vinculo com uma empresa?
                                <a class="text-sub" href="/registrar">Registre-se</a>.
                            </span>
                        </div>
                    </form>
                </div>
            </CardDestaque>

        </AnimatedContainer>
    </div>
</div>

@code {
    //Inputs user
    private string cpfDigitado = string.Empty;
    private string senhaDigitada = string.Empty;

    //Label erro
    private string geralErroLabel = string.Empty;
    private string cpfErroLabel = string.Empty;
    private string senhaErroLabel = string.Empty;
    //Dictionaty erro
    private Dictionary<string, string> erroDictionary = new();


    private async Task TryLogin()
    {
        if (SearchErrors()) return;

        //Finge login
        erroDictionary.Clear();
        try
        {
            throw new Exception();
        }
        catch
        {
            geralErroLabel = "Ocorreu um erro ao tentar fazer o login.";
            erroDictionary.Add("geral", geralErroLabel);
            return;
        }
    }

    private bool SearchErrors()
    {
        geralErroLabel = string.Empty;
        cpfErroLabel = string.Empty;
        senhaErroLabel = string.Empty;
        erroDictionary.Clear();

        if (cpfDigitado == string.Empty)
        {
            cpfErroLabel = "O cpf é obrigatório.";
            erroDictionary.Add("cpf", cpfErroLabel);
        }

        if (senhaDigitada == string.Empty)
        {
            senhaErroLabel = "A senha é obrigatória.";
            erroDictionary.Add("senha", senhaErroLabel);
        }

        if (erroDictionary.Count > 0) return true;
        return false;
    }
}