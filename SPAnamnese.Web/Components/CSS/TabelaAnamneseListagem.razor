@inject NavigationManager Navigation

<div class="table-responsive rounded-3 border">
    <table class="table table-hover align-middle mb-0">
        <thead>
            <tr class="table-light">
                <th class="text-nowrap px-3 py-3">
                    <i class="bi bi-person me-1 text-success"></i> Nome
                </th>
                <th class="text-nowrap px-3 py-3">CPF</th>
                <th class="text-nowrap px-3 py-3">Nascimento</th>
                <th class="text-nowrap px-3 py-3 text-center">Ações</th>
            </tr>
        </thead>
        <tbody>
            @if (pacientesLista?.Any() == true)
            {
                @foreach (var paciente in pacientesLista)
                {
                    <tr>
                        <td class="px-3 fw-semibold">
                            <a style="cursor: pointer;" @onclick="() => AoSelecionarPaciente.InvokeAsync(paciente)">@paciente.NOME</a>
                        </td>
                        <td class="px-3 text-muted font-monospace">@paciente.CPF</td>
                        <td class="px-3 text-muted">@paciente.DATANASCIMENTO.ToString("dd/MM/yyyy")</td>
                        <td class="px-3 text-center">

                            @if (!paciente.TEMANAMNESE)
                            {
                                <button class="btn btn-sm btn-outline-success"
                                        title="Visualizar anamnese"
                                        @onclick="@(() => Navigation.NavigateTo($"/anamnese/novo/{paciente.ID}"))">
                                    <i class="bi bi-plus-circle-fill"></i>
                                    <span class="d-none d-md-inline">Novo</span>
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-success"
                                        title="Visualizar anamnese"
                                        @onclick="@(() => Navigation.NavigateTo($"/anamnese/visualizar/{paciente.ID}"))">
                                    <i class="bi bi-eye-fill me-1"></i>
                                    <span class="d-none d-md-inline">Ver</span>
                                </button>

                                <button class="btn btn-sm btn-outline-success ms-2"
                                        title="Editar anamnese"
                                        @onclick="@(() => Navigation.NavigateTo($"/anamnese/editar/{paciente.ID}"))">
                                    <i class="bi bi-pencil-fill me-1"></i>
                                    <span class="d-none d-md-inline">Editar</span>
                                </button>
                            }

                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="99" class="text-center text-muted py-5">
                        <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                        Nenhum paciente cadastrado ainda.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="mt-2 px-1 d-flex align-items-center">
    <small class="text-muted">
        <i class="bi bi-people me-1"></i>
        @totalPacientes paciente(s) cadastrado(s)
    </small>

    <button class="btn btn-success btn-sm px-3 ms-auto"
            @onclick="@(() => Navigation.NavigateTo("/anamnese/novo-paciente"))">
        <i class="bi bi-plus-lg me-1"></i> Novo Paciente
    </button>
</div>

@code {
    [Parameter]
    public int totalPacientes { get; set; }

    [Parameter]
    public List<PacienteSistemaDTO>? pacientesLista { get; set; }

    [Parameter]
    public EventCallback<PacienteSistemaDTO> AoSelecionarPaciente { get; set; }
}