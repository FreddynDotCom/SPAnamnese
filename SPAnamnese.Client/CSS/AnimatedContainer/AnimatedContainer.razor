@inject IJSRuntime JS
@implements IAsyncDisposable

@if (Enabled)
{
    <div id="@_elementId"
         class="@Class"
         style="visibility:hidden;"
         @attributes="AdditionalAttributes">
        @ChildContent
    </div>
}
else
{
    @ChildContent
}

@code {
    [Parameter] public bool Enabled { get; set; } = true;

    /// Content to render and animate inside the container
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// CSS selector or null — scroll container for ScrollTrigger
    [Parameter] public string? Container { get; set; }

    /// Extra CSS classes for the wrapper div
    [Parameter] public string Class { get; set; } = "";

    /// Distance in pixels the element travels during animation
    [Parameter] public double Distance { get; set; } = 100;

    /// "vertical" or "horizontal"
    [Parameter] public string Direction { get; set; } = "vertical";

    /// Reverse the direction of travel
    [Parameter] public bool Reverse { get; set; } = false;

    /// Animation duration in seconds
    [Parameter] public double Duration { get; set; } = 0.8;

    /// GSAP easing for the entrance animation
    [Parameter] public string Ease { get; set; } = "power3.out";

    /// Starting opacity before animation
    [Parameter] public double InitialOpacity { get; set; } = 0;

    /// Whether to animate opacity
    [Parameter] public bool AnimateOpacity { get; set; } = true;

    /// Starting scale before animation
    [Parameter] public double Scale { get; set; } = 1;

    /// Intersection threshold that triggers the animation (0–1)
    [Parameter] public double Threshold { get; set; } = 0.1;

    /// Delay in seconds before animation starts
    [Parameter] public double Delay { get; set; } = 0;

    /// Seconds after entrance before disappearance starts. 0 = disabled.
    [Parameter] public double DisappearAfter { get; set; } = 0;

    /// Duration of the disappearance animation in seconds
    [Parameter] public double DisappearDuration { get; set; } = 0.5;

    /// GSAP easing for the disappearance animation
    [Parameter] public string DisappearEase { get; set; } = "power3.in";

    /// Callback fired when the entrance animation completes
    [Parameter] public EventCallback OnComplete { get; set; }

    /// Callback fired when the disappearance animation completes
    [Parameter] public EventCallback OnDisappearanceComplete { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private readonly string _elementId = $"ac-{Guid.NewGuid():N}"[..16];
    private IJSObjectReference? _module;
    private DotNetObjectReference<AnimatedContainer>? _dotnetRef;
    private bool _initialized = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _initialized || !Enabled) return;
        _initialized = true;

        try
        {
            _module = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./js/AnimatedContainer.js");

            _dotnetRef = DotNetObjectReference.Create(this);

            await _module.InvokeVoidAsync("start", new
            {
                elementId = _elementId,
                container = Container,
                distance = Distance,
                direction = Direction,
                reverse = Reverse,
                duration = Duration,
                ease = Ease,
                initialOpacity = InitialOpacity,
                animateOpacity = AnimateOpacity,
                scale = Scale,
                threshold = Threshold,
                delay = Delay,
                disappearAfter = DisappearAfter,
                disappearDuration = DisappearDuration,
                disappearEase = DisappearEase,
                dotnet = _dotnetRef
            });
        }
        catch (Exception ex) when (ex is TaskCanceledException or JSDisconnectedException) { }
    }

    [JSInvokable]
    public async Task OnCompleteCallback() => await OnComplete.InvokeAsync();

    [JSInvokable]
    public async Task OnDisappearanceCompleteCallback() => await OnDisappearanceComplete.InvokeAsync();

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try { await _module.InvokeVoidAsync("stop", _elementId); } catch { }
            try { await _module.DisposeAsync(); } catch { }
        }
        _dotnetRef?.Dispose();
    }
}